# Copy this to .env.local for local development
# In Vercel: add these under Project Settings > Environment Variables

# Betfair Exchange API key (get from developer.betfair.com)
BETFAIR_API_KEY=your_betfair_key_here

# Betfair App Key (also from developer.betfair.com)
BETFAIR_APP_KEY=your_app_key_here

# Optional: cache TTL in seconds (default 300 = 5 min)
CACHE_TTL=300
